--checking last 3 cols with sales, quantity and price
-- >> sales = Quantity * price
--- >> Values must not be null or zero or neative
-- this having a issues like -ve, null, 0
SELECT DISTINCT
sls_sales,
sls_quantity,
sls_price
FROM bronze.crm_sales_details
WHERE sls_sales != sls_quantity * sls_price
OR sls_sales IS NULL OR sls_quantity IS NULL OR sls_price IS NULL
OR sls_sales <= 0 OR sls_quantity <= 0 OR sls_price <= 0
order by sls_sales, sls_quantity, sls_price

--Solution1) Data issues will be fixed direct in source system
-- solution2) Data issues has to be fixed in data warehouse

--if slaes is negative , zero, null derive it using quantity and price
--if price is zero or null , calculate it using sales and quantity
-- if price is negative, convert it to a positive value.
-- correcting

SELECT DISTINCT
sls_sales as old_sls_sales,
sls_quantity,
sls_price as old_sls_price,
CASE WHEN sls_sales IS NULL OR sls_sales <= 0  OR sls_sales != sls_quantity * abs(sls_price)
		THEN sls_quantity * abs(sls_price)
	ELSE sls_sales
END AS sls_sales,
CASE WHEN sls_price IS NULL OR sls_price <= 0
		THEN sls_sales/ NULLIF(sls_quantity, 0)
	ELSE sls_price
END AS sls_price
FROM bronze.crm_sales_details

